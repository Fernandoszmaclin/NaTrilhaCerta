# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_LOG_LEVEL=INFO

# Database (use DB_ENGINE=sqlite para usar SQLite local)
DB_ENGINE=postgresql
DB_NAME=trilhacerta_db
DB_USER=trilhacerta_user
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# Cache compartilhado para rate limiting (recomendado em produção).
# Se vazio em produção, usa cache no banco — rode antes: manage.py createcachetable
# REDIS_URL=redis://localhost:6379/0
REDIS_URL=

# Gateway de pagamento (HMAC para validar assinatura do webhook)
PAYMENT_WEBHOOK_SECRET=
